{
  "name": "@tier0/sdk",
  "version": "0.1.0",
  "description": "Tier0 SDK - OpenAPI REST client and MQTT over WebSocket client for TypeScript/JavaScript",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./openapi": {
      "import": "./dist/openapi/index.js",
      "require": "./dist/openapi/index.js",
      "types": "./dist/openapi/index.d.ts"
    },
    "./mq": {
      "import": "./dist/mq/index.js",
      "require": "./dist/mq/index.js",
      "types": "./dist/mq/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "generate": "bash scripts/generate-openapi.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "optionalDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "mqtt": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "openapi-typescript": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FREEZONEX/Tier0-sdk.git"
  },
  "keywords": ["tier0", "sdk", "openapi", "mqtt", "uns", "iot"],
  "engines": {
    "node": ">=18.0.0"
  }
}
