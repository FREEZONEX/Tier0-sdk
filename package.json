{
  "name": "@tier0/sdk",
  "version": "0.2.6",
  "description": "Tier0 SDK - OpenAPI REST client and MQTT over WebSocket client for TypeScript/JavaScript",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./openapi": {
      "types": "./dist/esm/openapi/index.d.ts",
      "import": "./dist/esm/openapi/index.js",
      "require": "./dist/cjs/openapi/index.js"
    },
    "./openapi/react": {
      "types": "./dist/esm/openapi/react.d.ts",
      "import": "./dist/esm/openapi/react.js",
      "require": "./dist/cjs/openapi/react.js"
    },
    "./openapi/vue": {
      "types": "./dist/esm/openapi/vue.d.ts",
      "import": "./dist/esm/openapi/vue.js",
      "require": "./dist/cjs/openapi/vue.js"
    },
    "./mq": {
      "types": "./dist/esm/mq/index.d.ts",
      "import": "./dist/esm/mq/index.js",
      "require": "./dist/cjs/mq/index.js"
    }
  },
  "files": [
    "dist/",
    "skills/"
  ],
  "agents": {
    "skills": [
      { "name": "tier0-sdk", "path": "./skills/tier0-sdk" }
    ]
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && node scripts/finalize-build.mjs",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "generate": "bash scripts/generate-openapi.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "optionalDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "mqtt": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "openapi-typescript": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FREEZONEX/Tier0-sdk.git"
  },
  "keywords": [
    "tier0",
    "sdk",
    "openapi",
    "mqtt",
    "uns",
    "iot"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
